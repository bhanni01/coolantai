# Copy to .env.local for local overrides:  cp .env.example .env.local
#
# Backend base URL for POST /run and the /run/{id}/events SSE stream.
# Defaults to http://localhost:8000 when unset.
VITE_API_BASE=http://localhost:8000

# Offline demo fallback. Set to "true" to drive the dashboard from the built-in
# mock state machine instead of the live backend — a guaranteed-to-work path for
# a live demo if the API has a bad moment. Any other value (or unset) = live.
VITE_USE_MOCK=false
