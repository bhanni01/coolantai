# Copy this file to .env and fill in your actual values:  cp .env.example .env
#
# Required
# --------
# OpenAI API key — the only hard requirement; ingest and main.py exit without it.
OPENAI_API_KEY=sk-...your-openai-api-key-here...

# Optional — LangSmith tracing
# ----------------------------
# If LANGSMITH_API_KEY is set, main.py traces the full run to LangSmith and
# prints the trace URL; without it the run works fine but is not traced.
# LANGCHAIN_API_KEY is accepted as a legacy alias.
LANGSMITH_API_KEY=lsv2_...your-langsmith-api-key...

# Optional overrides (main.py already defaults these when tracing is on):
# LANGSMITH_TRACING=true          # legacy alias: LANGCHAIN_TRACING_V2
# LANGSMITH_PROJECT=coolant-copilot
